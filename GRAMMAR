<stmt> ::=
      <stmt-block>
    | <stmt-variable>
    | <stmt-loop>
    | <stmt-if>
    | <expr>
    | "return" <expr-tuple>
    | "break"
    | "continue"
    | ";"
	helium_token_type_keyword_if
	helium_token_type_keyword_else

<stmt-if> ::=
      "if" <expr> <stmt-block>
    | "if" <expr> <stmt-block> "else" <stmt-block>
    | "if" <expr> <stmt-block> "else" <stmt-if>

<stmt-loop> ::=
      "for" <expr-opt>;<expr-opt>;<expr-opt> <stmt-block>
    | "for" <expr-opt> <stmt-block>
    | "for" <stmt-block>

<stmt-sequence-opt> ::= "" | <stmt-sequence>
<stmt-sequence> ::= <stmt> | <stmt><stmt-sequence> | <stmt>;<stmt-sequence>
<stmt-block-opt> ::= "" | <stmt-block>
<stmt-block> ::= <qualifers-opt> "{" <stmt-sequence-opt> "}"

<qualifers-opt> ::= "" | <qualifers> 
<qualifers> ::=
      "var"
    | "const"
    | "runtime"
    | "comptime"
    | "var" <qualifers>
    | "const" <qualifers>
    | "runtime" <qualifers>
    | "comptime" <qualifers>

<stmt-variable> ::=
      <qualifers> <identifier> ":" <expr>
    | <qualifers> <identifier> ":" <expr>

<expr-opt> ::= "" | <expr>
<expr> ::= <qualifers-opt><expr-unqualified>

<expr-unqualified-opt> ::= "" | <expr-unqualified>
<expr-unqualified> ::=
      <number>
    | <identifier>
    | <string>
    | <expr-func>
    | <expr-tuple>
    | <type-array>
    | <type-opt>
    | <type-varidic>
    | <expr-init>
    | <expr-range>
    | <expr-func-call>
    | <expr-oper-call>
    | <expr-member>
    | <expr-index>
    | <type-struct>
    | <type-union>
    | <type-enum>
    | "type"
    | "nothing"
    | <expr-typeof>
    | <stmt-block>

<type-enum> ::=
      "enum" "{" <enumarations-opt> "}"
    | "enum" "(" <expr> ")" "{" <enumarations-opt> "}"

<expr-typeof> ::= "typeof" "(" <expr> ")"

<func-params-opt> ::= "" | <func-params>
<func-params> ::= <func-param> | <func-param>,<func-params>
<func-param> ::= <identifier>":"<expr> | <identifier>":"<expr>=<expr>
<expr-func> ::= "func" "(" <func-params-opt> ")" <expr> <stmt-block-opt>

<expr-tuple-list> ::= <expr> | <expr><expr-tuple-list>
<expr-tuple> ::= "(" ")" | "("<expr-tuple-list>")"

<type-array> ::= "["<expr-opt>"]"<expr>

<type-opt> ::= "?"<expr>

<type-varidic> ::= <expr>"..."

<struct-fields-opt> ::= "" | <struct-fields>
<struct-fields> ::= <struct-field> | <struct-field>"," | <struct-field><struct-fields> | <struct-field>","<struct-fields>
<struct-field> ::=
      <identifier>":"<expr>
    | "pub" <identifier>":"<expr>
    | <identifier>:<expr>"="<expr>
    | "pub" <identifier>":"<expr>"="<expr>
    | <stmt-variable>
    | "pub" <stmt-variable>
    
<type-struct> ::= "struct" "{"<struct-fields-opt>"}"

<type-union> ::=
      "union" {<struct-fields-opt>} 
    | "union" "("<expe>")" "{"<struct-fields-opt>"}"

<init-field> ::= <identifier>"="<expr> | <expr>
<init-fields> ::= <init-field> | <init-field>"," | <init-field>","<init-fields>
<init-fields-opt> ::= "" | <init-fields>
<expr-init> ::= <expr-opt>"{"<init-fields-opt>"}"

<expr-range> ::= <expr>".."<expr>

<expr-func-call> ::= <expr>"("<init-fields-opt>")"

<expr-oper> ::=
      "+"
    | "-"
    | "/"
    | "*"
    | "~"
    | "^"
    | "&"
    | "|"
    | "<<"
    | ">>"
    | "and"
    | "or"
    | "not"
    | "=="
    | "!="
    | "<"
    | ">"
    | "<="
    | ">="
    | ".."

<expr-oper-call> ::= <expr-oper>"("<init-fields-opt>")"

<expr-member> ::= <expr>"."<identifier>

<expr-index> ::= <expr>"["<expr>"]"